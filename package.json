{
  "name": "my-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "prepare": "husky install",
    "dev": "next dev",
    "start": "next start",
    "build": "npm run _generate:rss && next build",
    "_generate:rss": "cross-env NODE_OPTIONS=--loader=ts-node/esm ts-node --project tsconfig.json --require tsconfig-paths/register libs/rss-generate.ts",
    "_lint": "eslint .",
    "_typecheck": "tsc --noEmit -p tsconfig.json",
    "_format": "prettier . --write",
    "_format:check": "prettier . --check"
  },
  "dependencies": {
    "@jho951/ui-components": "^0.1.3",
    "@reduxjs/toolkit": "^2.11.2",
    "accept-language": "^3.0.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.19.2",
    "gray-matter": "^4.0.3",
    "lodash": "^4.17.21",
    "marked": "^16.0.0",
    "next": "15.3.4",
    "next-auth": "^4.24.11",
    "next-mdx-remote": "^5.0.0",
    "openai": "^5.11.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-redux": "^9.2.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "rss": "^1.2.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.30.1",
    "@svgr/webpack": "^8.1.0",
    "@types/lodash": "^4.17.20",
    "@types/marked": "^5.0.2",
    "@types/node": "^20",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/rss": "^0.0.32",
    "@types/webpack": "^5.28.5",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.4.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "webpack": "^5.100.1"
  }
}
